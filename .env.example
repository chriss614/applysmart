# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ============================================
# JWT Secrets (generate strong random strings)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-64-characters-long-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-characters-long-change-me

# ============================================
# Upstash Redis (for rate limiting)
# Get from: https://console.upstash.com/
# ============================================
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# OpenAI
# Get from: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Resend (email)
# Get from: https://resend.com/api-keys
# ============================================
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@applysmart.io

# ============================================
# Lemon Squeezy (payments)
# Get from: https://app.lemonsqueezy.com/settings/api
# ============================================
LEMON_SQUEEZY_API_KEY=your-ls-api-key
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMON_SQUEEZY_PRO_VARIANT_ID=your-pro-variant-id
LEMON_SQUEEZY_ACCELERATOR_VARIANT_ID=your-accelerator-variant-id

# ============================================
# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Vercel Blob (file uploads)
# Get from: https://vercel.com/dashboard/stores/blob
# ============================================
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# ============================================
# App URLs
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
